# 硅基流动 API 配置
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
RESUME_LAYOUT_MODEL=Qwen/Qwen3.6-Plus
RESUME_LAYOUT_API_KEY=your_resume_layout_api_key_here
RESUME_LAYOUT_BASE_URL=https://api.siliconflow.cn/v1
RESUME_OPTIMIZE_LLM_TIMEOUT_SECONDS=75
RESUME_OPTIMIZE_ROUTE_TIMEOUT_SECONDS=110
RESUME_OPTIMIZE_LLM_RETRIES=1

# 数据库配置（如果需要）
RESUME_DB_PATH=data/resume.db
SUPABASE_DATABASE_URL=postgresql://postgres.project-ref:your_password@host:6543/postgres
POSTGRES_POOL_MIN_CONN=1
POSTGRES_POOL_MAX_CONN=5

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
